{
  "indentStyle": "space",
  "indentWidth": 2,
  "lineWidth": 120,
  "semi": false,
  "singleQuote": true,
  "jsxSingleQuote": false,
  "trailingComma": "all",
  "arrowParens": "always",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "ignorePatterns": [
    "node_modules",
    "dist",
    ".git",
    ".direnv",
    ".env",
    ".env.example",
    "flake.lock",
    "flake.nix",
  ]
}
